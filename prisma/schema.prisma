generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  email                          String           @unique
  name                           String
  passwordHash                   String
  role                           Role             @default(USER)
  createdAt                      DateTime         @default(now())
  updatedAt                      DateTime         @default(now()) @updatedAt
  id                             String           @id
  deletedAt                      DateTime?
  comments                       Comment[]
  Ticket_Ticket_assigneeIdToUser Ticket[]         @relation("Ticket_assigneeIdToUser")
  ownedTickets                   Ticket[]         @relation("TicketOwner")
  activities                     TicketActivity[]
}

model Ticket {
  id                           String           @id
  subject                      String
  description                  String
  priority                     String
  status                       TicketStatus     @default(open)
  createdAt                    DateTime         @default(now())
  updatedAt                    DateTime         @updatedAt
  userId                       String
  closedAt                     DateTime?
  assigneeId                   String?
  comments                     Comment[]
  User_Ticket_assigneeIdToUser User?            @relation("Ticket_assigneeIdToUser", fields: [assigneeId], references: [id])
  user                         User             @relation("TicketOwner", fields: [userId], references: [id])
  activities                   TicketActivity[]

  @@index([userId])
  @@index([status])
  @@index([assigneeId])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  ticketId  String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  author    User     @relation(fields: [authorId], references: [id])
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([authorId])
}

model TicketActivity {
  id        String   @id @default(cuid())
  ticketId  String
  actorId   String
  action    String
  detail    String?
  createdAt DateTime @default(now())
  actor     User     @relation(fields: [actorId], references: [id])
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([actorId])
}

enum Role {
  USER
  ADMIN
}

enum TicketStatus {
  open
  closed
  in_progress
  pending
}
